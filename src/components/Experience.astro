---
import ExperienceItem from './ExperienceItem.astro';
import data from '../data/portafolio.json';

function formatDate(dateStr: string) {
    if (dateStr === 'Present') return 'Actualmente';
    const [year, month] = dateStr.split('-');
    if (!month) return dateStr;
    const months = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
    return `${months[parseInt(month) - 1]} ${year}`;
}

const jobs = data.experience.map((exp) => ({
    title: exp.role,
    company: exp.company,
    url: exp.url,
    period: `${formatDate(exp.startDate)} - ${formatDate(exp.endDate)}`,
    achievements: exp.responsibilities,
    tags: exp.skills || []
}));
---

<section id='experience' class='py-20 animate-fade-in'>
    <div class='container mx-auto px-4 md:px-6'>
        <div class='text-left mb-12'>
            <h2 class='text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4'>Experiencia</h2>
            <div class='h-1 w-20 bg-accent rounded-full mb-4'></div>
            <p class='text-muted-foreground'>Mi trayectoria profesional en el desarrollo de software y sistemas de información.</p>
        </div>

        <div class='space-y-8'>
            {jobs.map((job) => <ExperienceItem {...job} />)}
        </div>
    </div>
</section>
